{
  "displayName": "SmartRent",
  "name": "@prismwizard/homebridge-smartrent",
  "version": "5.0.0",
  "description": "Homebridge plugin for SmartRent installations (fork with broadened Node.js support, bug fixes, and new device types)",
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "hap",
    "homekit",
    "smartrent"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Brandon Warren",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somekindawizard/homebridge-smartrent.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.example.json",
    "config.schema.json",
    "CHANGELOG.md",
    "screenshot.png"
  ],
  "scripts": {
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "clean": "rimraf ./dist",
    "compile": "tsc",
    "build": "npm-run-all clean compile",
    "watch": "npm run dev-setup && npm run build && npm link && nodemon",
    "prepublishOnly": "npm-run-all prettier lint build test",
    "test": "node --test --import tsx test/*.test.ts",
    "prepare": "husky",
    "tsc": "tsc --noEmit",
    "dev-setup": "npm run setup-config && npm run setup-log",
    "setup-config": "if [ ! -f ./test/hbConfig/config.json ]; then cp ./test/hbConfig/config-template.json ./test/hbConfig/config.json; fi",
    "setup-log": "touch $(pwd)/test/hbConfig/homebridge.log && sed -i.bak \"s|<log_file>|$(pwd)/test/hbConfig/homebridge.log|g\" $(pwd)/test/hbConfig/config.json && rm -f $(pwd)/test/hbConfig/config.json.bak"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "axios": "^1.7.9",
    "homebridge-lib": "^7.1.1",
    "jwt-decode": "^4.0.0",
    "otplib": "^12.0.1",
    "ws": "^8.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "24.12.2",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "homebridge": "1.11.4",
    "homebridge-config-ui-x": "5.21.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "nodemon": "3.1.14",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/somekindawizard/homebridge-smartrent/issues"
  },
  "homepage": "https://github.com/somekindawizard/homebridge-smartrent#readme"
}
