{
  "displayName": "SmartRent",
  "name": "@jabrown93/homebridge-smartrent",
  "version": "2.2.1",
  "description": "Homebridge plugin for SmartRent installations",
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "hap",
    "homekit",
    "smartrent"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Jared Brown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jabrown93/homebridge-smartrent.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "files": [
    "src",
    "dist",
    "config.example.json",
    "config.schema.json",
    "CHANGELOG.md",
    "screenshot.png"
  ],
  "scripts": {
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint src/**.ts",
    "lint:fix": "eslint src/**.ts --fix",
    "clean": "rimraf ./dist",
    "compile": "tsc",
    "build": "npm-run-all clean compile",
    "watch": "npm run dev-setup && npm run build && npm link && nodemon",
    "prepublishOnly": "npm-run-all prettier lint build",
    "semantic-release": "cross-env semantic-release --no-ci",
    "release": "npm-run-all build semantic-release",
    "test": "echo \"Error: no test specified\" && exit 0",
    "prepare": "husky",
    "tsc": "tsc --noEmit",
    "dev-setup": "npm run setup-config && npm run setup-log",
    "setup-config": "if [ ! -f ./test/hbConfig/config.json ]; then cp ./test/hbConfig/config-template.json ./test/hbConfig/config.json; fi",
    "setup-log": "touch $(pwd)/test/hbConfig/homebridge.log && sed -i '' \"s|<log_file>|$(pwd)/test/hbConfig/homebridge.log|g\" $(pwd)/test/hbConfig/config.json"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "axios": "^1.7.9",
    "homebridge-lib": "^7.1.1",
    "jwt-decode": "^4.0.0",
    "otplib": "^12.0.1",
    "ws": "^8.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.2",
    "@semantic-release/npm": "13.1.3",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/node": "24.10.4",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.52.0",
    "@typescript-eslint/parser": "8.52.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "homebridge": "1.11.1",
    "homebridge-config-ui-x": "5.14.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "nodemon": "3.1.11",
    "npm-run-all2": "8.0.4",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "semantic-release": "25.0.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/jabrown93/homebridge-smartrent/issues"
  },
  "homepage": "https://github.com/jabrown93/homebridge-smartrent#readme"
}
